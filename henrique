local cachedNilRemote = nil
local lastNilCache = 0
local NilCacheInterval = 2

local function getCachedNilRemote()
    local now = tick()
    if now - lastNilCache < NilCacheInterval and cachedNilRemote then
        return cachedNilRemote
    end
    lastNilCache = now
    for _, v in next, getnilinstances() do
        if v.ClassName == "RemoteEvent" and v.Name == "RemoteEvent" then
            cachedNilRemote = v
            return v
        end
    end
    cachedNilRemote = nil
    return nil
end

local cachedMobs = {}
local lastCacheUpdate = 0
local CacheInterval = 1

local function updateMobCache()
    local now = tick()
    if now - lastCacheUpdate < CacheInterval then return end
    lastCacheUpdate = now

    local newCache = {}
    for _, zoneFolder in ipairs(MobsFolder:GetChildren()) do
        if zoneFolder:IsA("Folder") or zoneFolder:IsA("Model") then
            for _, mob in ipairs(zoneFolder:GetChildren()) do
                if mob:IsA("Model") then
                    local humanoid = mob:FindFirstChildOfClass("Humanoid")
                    if humanoid and humanoid.Health > 0 then
                        table.insert(newCache, mob)
                    end
                end
            end
        end
    end
    cachedMobs = newCache
end

MobsFolder.DescendantAdded:Connect(function(desc)
    if desc:IsA("Model") and desc:FindFirstChildOfClass("Humanoid") then
        lastCacheUpdate = 0
    end
end)

MobsFolder.DescendantRemoving:Connect(function(desc)
    if desc:IsA("Model") then
        lastCacheUpdate = 0
    end
end)

local function getCharacter()
    local char = LocalPlayer.Character
    if not char then return nil end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return nil end
    return char, hrp
end

local function getClosestMob()
    local char, hrp = getCharacter()
    if not hrp then return nil end

    local closest = nil
    local minDist = Range
    local myPos = hrp.Position

    for _, mob in ipairs(cachedMobs) do
        if mob.Parent then
            local mobHRP = mob:FindFirstChild("HumanoidRootPart") or mob:FindFirstChild("Torso") or mob:FindFirstChild("UpperTorso")
            if mobHRP then
                local dist = (myPos - mobHRP.Position).Magnitude
                if dist < minDist then
                    minDist = dist
                    closest = mob
                end
            end
        end
    end
    return closest
end

local function getEquippedSword()
    local char = LocalPlayer.Character
    if not char then return nil end
    for _, name in ipairs(SwordNames) do
        local sword = char:FindFirstChild(name)
        if sword then
            return sword
        end
    end
    return nil
end

local function attack()
    local args = {1}
    local sword = getEquippedSword()
    if sword then
        local slash = sword:FindFirstChild("Slash")
        if slash then
            slash:FireServer(unpack(args))
        end
    end
    local nilRemote = getCachedNilRemote()
    if nilRemote then
        nilRemote:FireServer(unpack(args))
    end
end

RunService.Heartbeat:Connect(function()
    if not KillAuraEnabled then return end

    local now = tick()
    if now - LastAttack < AttackCooldown then return end

    local char, hrp = getCharacter()
    if not hrp then return end

    updateMobCache()

    local target = getClosestMob()
    if target then
        LastAttack = now
        attack()
    end
end)

