local RollEnabled = true
local RollCooldown = 0
local LastRoll = 0

local function doRoll(direction)
    local char, hrp = getCharacter()
    if not hrp then return end

    local humanoid = char:FindFirstChildOfClass("Humanoid")
    if not humanoid then return end

    local moveDir = direction or humanoid.MoveDirection
    if moveDir.Magnitude < 0.01 then
        moveDir = hrp.CFrame.LookVector
    end

    local rollArgs = {
        Origin = hrp.Position,
        End = hrp.Position + moveDir * 40
    }

    Remotes.Roll:FireServer(rollArgs)

    local rollForce = Instance.new("BodyVelocity")
    rollForce.Name = "RollForce"
    rollForce.Velocity = moveDir.Unit * 55
    rollForce.MaxForce = Vector3.new(40000, 0, 40000)
    rollForce.Parent = hrp
    game.Debris:AddItem(rollForce, 0.3)
end

UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed then return end
    if not RollEnabled then return end

    if input.KeyCode == Enum.KeyCode.Q or input.KeyCode == Enum.KeyCode.ButtonB then
        local now = tick()
        if now - LastRoll < RollCooldown then return end
        LastRoll = now

        doRoll()
    end
end)

