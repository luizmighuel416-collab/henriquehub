local AntiFallEnabled = false

local function setupAntiFallDamage()
    local char = LocalPlayer.Character
    if not char then return end

    local humanoid = char:FindFirstChildOfClass("Humanoid")
    if not humanoid then return end

    humanoid:SetStateEnabled(Enum.HumanoidStateType.FallingDown, false)
    humanoid:SetStateEnabled(Enum.HumanoidStateType.Ragdoll, false)

    local lastVelocity = Vector3.zero

    RunService.Heartbeat:Connect(function()
        if not AntiFallEnabled then return end
        if not LocalPlayer.Character then return end
        local hum = LocalPlayer.Character:FindFirstChildOfClass("Humanoid")
        if not hum then return end

        hum:SetStateEnabled(Enum.HumanoidStateType.FallingDown, false)
        hum:SetStateEnabled(Enum.HumanoidStateType.Ragdoll, false)

        local hrp = LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
        if hrp then
            if hrp.Velocity.Y < -50 then
                hrp.AssemblyLinearVelocity = Vector3.new(hrp.Velocity.X, math.max(hrp.Velocity.Y, -50), hrp.Velocity.Z)
            end
            lastVelocity = hrp.Velocity
        end
    end)

    humanoid.StateChanged:Connect(function(_, newState)
        if not AntiFallEnabled then return end
        if newState == Enum.HumanoidStateType.Landed then
            local hrp = char:FindFirstChild("HumanoidRootPart")
            if hrp then
                hrp.AssemblyLinearVelocity = Vector3.new(lastVelocity.X, 0, lastVelocity.Z)
            end
            task.delay(0, function()
                if humanoid then
                    humanoid:ChangeState(Enum.HumanoidStateType.Running)
                end
            end)
        end
    end)
end

setupAntiFallDamage()

