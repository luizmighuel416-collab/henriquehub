local EspPlayersEnabled = false
local EspEnemiesEnabled = false

local PlayerEspData = {}
local EnemyEspData = {}

local function createHighlight(parent, color)
    local hl = Instance.new("Highlight")
    hl.Name = "RariedadeESP"
    hl.FillColor = color
    hl.OutlineColor = color
    hl.FillTransparency = 0.5
    hl.OutlineTransparency = 0
    hl.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
    hl.Parent = parent
    return hl
end

local function createBillboard(parent, text, color)
    local bb = Instance.new("BillboardGui")
    bb.Name = "RariedadeESP"
    bb.Size = UDim2.new(0, 100, 0, 20)
    bb.StudsOffset = Vector3.new(0, 3, 0)
    bb.AlwaysOnTop = true
    bb.MaxDistance = 500
    bb.Parent = parent

    local label = Instance.new("TextLabel")
    label.Name = "ESPLabel"
    label.Size = UDim2.new(1, 0, 1, 0)
    label.BackgroundTransparency = 1
    label.Text = text
    label.TextColor3 = color
    label.TextStrokeTransparency = 0
    label.TextStrokeColor3 = Color3.new(0, 0, 0)
    label.TextScaled = false
    label.TextSize = 12
    label.Font = Enum.Font.GothamBold
    label.Parent = bb

    return bb
end

local function clearEsp(dataTable)
    for _, entry in pairs(dataTable) do
        if entry.highlight and entry.highlight.Parent then
            entry.highlight:Destroy()
        end
        if entry.billboard and entry.billboard.Parent then
            entry.billboard:Destroy()
        end
    end
    table.clear(dataTable)
end

local function removeEsp(dataTable, key)
    local entry = dataTable[key]
    if entry then
        if entry.highlight and entry.highlight.Parent then
            entry.highlight:Destroy()
        end
        if entry.billboard and entry.billboard.Parent then
            entry.billboard:Destroy()
        end
        dataTable[key] = nil
    end
end

local function updatePlayerEsp()
    if not EspPlayersEnabled then
        clearEsp(PlayerEspData)
        return
    end

    for _, player in ipairs(Players:GetPlayers()) do
        if player == LocalPlayer then continue end

        local char = player.Character
        if not char then
            removeEsp(PlayerEspData, player)
            continue
        end

        local hrp = char:FindFirstChild("HumanoidRootPart")
        if not hrp then
            removeEsp(PlayerEspData, player)
            continue
        end

        local hum = char:FindFirstChildOfClass("Humanoid")
        if hum and hum.Health <= 0 then
            removeEsp(PlayerEspData, player)
            continue
        end

        local entry = PlayerEspData[player]
        if not entry then
            entry = {}
            PlayerEspData[player] = entry
        end

        if not entry.highlight or not entry.highlight.Parent then
            entry.highlight = createHighlight(char, Color3.new(0, 1, 0))
        end

        local displayName = player.DisplayName or player.Name
        if not entry.billboard or not entry.billboard.Parent then
            entry.billboard = createBillboard(hrp, displayName, Color3.new(0, 1, 0))
        else
            entry.billboard.ESPLabel.Text = displayName
        end
    end

    for player in pairs(PlayerEspData) do
        if not table.find(Players:GetPlayers(), player) then
            removeEsp(PlayerEspData, player)
        end
    end
end

local function updateEnemyEsp()
    if not EspEnemiesEnabled then
        clearEsp(EnemyEspData)
        return
    end

    updateMobCache()

    local activeMobs = {}
    for _, mob in ipairs(cachedMobs) do
        if mob.Parent then
            activeMobs[mob] = true

            local hrp = mob:FindFirstChild("HumanoidRootPart") or mob:FindFirstChild("Torso") or mob:FindFirstChild("UpperTorso")
            if not hrp then
                removeEsp(EnemyEspData, mob)
                continue
            end

            local entry = EnemyEspData[mob]
            if not entry then
                entry = {}
                EnemyEspData[mob] = entry
            end

            if not entry.highlight or not entry.highlight.Parent then
                entry.highlight = createHighlight(mob, Color3.new(1, 0, 0))
            end

            local mobName = mob.Name
            if not entry.billboard or not entry.billboard.Parent then
                entry.billboard = createBillboard(hrp, mobName, Color3.new(1, 0, 0))
            else
                entry.billboard.ESPLabel.Text = mobName
            end
        end
    end

    for mob in pairs(EnemyEspData) do
        if not activeMobs[mob] or not mob.Parent then
            removeEsp(EnemyEspData, mob)
        end
    end
end

RunService.Heartbeat:Connect(function()
    updatePlayerEsp()
    updateEnemyEsp()
end)

